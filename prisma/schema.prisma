generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mongodb"
}

enum Role {
  ADMIN
  EXECUTIVE
  SUPER_ADMIN
  SALES
  ANALYST
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum LeadActivityType {
  NOTE
  STATUS_CHANGE
  ASSIGNMENT
  ATTACHMENT
}

// User model for Admin and Executive roles
model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leadActivities LeadActivity[]
  assignedLeads   QuoteRequest[] @relation("LeadAssignee")
  notifications  Notification[]
  auditLogs      AuditLog[]
}

// Products/Equipment catalog
model Product {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  slug            String   @unique @default(cuid()) // URL friendly identifier
  description     String?
  details         String?  // Rich text or detailed specs
  category        String // EQUIPAMENTOS | SILOS | ACESSORIOS | OUTROS
  image           String?
  images          String?  // JSON string for multiple images
  isFeatured      Boolean  @default(false)
  priceRequestCnt Int      @default(0) // Analytics counter
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  quoteRequests   QuoteRequest[]
}

// Leads and Quote Requests generated from the public site
model QuoteRequest {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String
  phone       String?
  company     String?
  message     String?
  
  equipmentId String? @db.ObjectId // Optional relation if they asked for a specific product
  product     Product? @relation(fields: [equipmentId], references: [id])
  
  status      LeadStatus @default(NEW)
  assigneeId  String? @db.ObjectId
  assignee    User? @relation("LeadAssignee", fields: [assigneeId], references: [id])
  expectedValue Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities LeadActivity[]
}

// Daily/Monthly snapshots for the Executive Dashboard
model AnalyticsSnapshot {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  date          DateTime @unique // Usually truncated to YYYY-MM-DD
  totalLeads    Int      @default(0)
  openProposals Int      @default(0)
  wonDeals      Int      @default(0)
  createdAt     DateTime @default(now())
}

model LeadActivity {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  leadId      String           @db.ObjectId
  lead        QuoteRequest     @relation(fields: [leadId], references: [id])
  userId      String?          @db.ObjectId
  user        User?            @relation(fields: [userId], references: [id])
  type        LeadActivityType
  description String
  createdAt   DateTime         @default(now())
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  type      String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}

model Goal {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  title        String
  metric       String
  targetValue  Float
  currentValue Float    @default(0)
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}
